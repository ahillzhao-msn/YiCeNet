# YiCeNet Environment Variables
# Copy this to .env and fill in your API keys.

# API key for reward scoring (training/evaluation).
# Set EVAL_API_URL + EVAL_MODEL to use a different provider.
# For DeepSeek (default):
EVAL_API_KEY=sk-xxxxxxxxxxxxxxxx

# Alternative: legacy env name (still supported for backward compat)
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# To use a different OpenAI-compatible provider, uncomment & set:
# EVAL_API_URL=http://localhost:8000/v1/chat/completions
# EVAL_MODEL=qwen2.5-7b-instruct
