# Docker build context: exclude heavy/unnecessary files

# Git
.git/
.gitignore

# Python cache
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Checkpoints (too large for build context)
checkpoints/*.pt
checkpoints/registry.json

# Local data
data/*.db
data/*.db-journal

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Design docs (not needed at runtime)
yicenet_architecture.md
yicenet_work_plan.md
yicenet_deployment.md
yicenet_deployment_container.md
deploy_design.md

# Source docs
README.md
